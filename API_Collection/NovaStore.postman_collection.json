{
  "info": {
    "name": "Nova Store API",
    "description": "Nova Store REST API.\n\n**Setup:** set `baseUrl` (collection variable) to your API root, e.g.\n`http://localhost:4000/api` or `https://novastore.onrender.com/api`\n\n**Login first** \u2014 the Login request auto-saves the JWT into the `token` variable, so every protected request just works. Seeded admin: `admin@nova.com` / `admin123`.\n\nRun folders in order for a full demo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "productId",
      "value": "1"
    },
    {
      "key": "orderId",
      "value": "1"
    },
    {
      "key": "customerId",
      "value": "2"
    }
  ],
  "item": [
    {
      "name": "0. Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "No auth. Use this to wake a sleeping Render instance before a demo."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('API is up', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login (admin) \u2014 saves token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Run this FIRST. Saves the JWT to {{token}} automatically.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@nova.com\",\n  \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.token) {",
                  "  pm.collectionVariables.set('token', d.token);",
                  "  console.log('Token saved:', d.user ? d.user.role : '');",
                  "}",
                  "pm.test('Login OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Register new user \u2014 saves token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a regular user and overwrites {{token}} with their JWT. Re-run Login (admin) to get admin rights back.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"student@nova.com\",\n  \"password\": \"secret123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.token) {",
                  "  pm.collectionVariables.set('token', d.token);",
                  "  console.log('Token saved:', d.user ? d.user.role : '');",
                  "}",
                  "pm.test('Registered', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (user)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@nova.com\",\n  \"password\": \"secret123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.token) {",
                  "  pm.collectionVariables.set('token', d.token);",
                  "  console.log('Token saved:', d.user ? d.user.role : '');",
                  "}",
                  "pm.test('Login OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get current user",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            },
            "description": "Returns the profile for whoever {{token}} belongs to."
          }
        }
      ]
    },
    {
      "name": "2. Products (public reads)",
      "item": [
        {
          "name": "List all products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            },
            "description": ""
          }
        },
        {
          "name": "Filter by category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?category=Electronics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "Electronics"
                }
              ]
            },
            "description": ""
          }
        },
        {
          "name": "Search by name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?search=watch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "watch"
                }
              ]
            },
            "description": ""
          }
        },
        {
          "name": "Featured only",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?featured=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "featured",
                  "value": "true"
                }
              ]
            },
            "description": ""
          }
        },
        {
          "name": "Sort by price ascending",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?sort=price_asc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "sort",
                  "value": "price_asc"
                }
              ]
            },
            "description": "sort accepts: price_asc, price_desc, rating"
          }
        },
        {
          "name": "Get one product",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}"
              ]
            },
            "description": ""
          }
        }
      ]
    },
    {
      "name": "3. Products (admin writes)",
      "item": [
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            },
            "description": "Admin only. Saves the new id into {{productId}}.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mechanical Keyboard\",\n  \"price\": 74.99,\n  \"oldPrice\": 99.99,\n  \"category\": \"Electronics\",\n  \"stock\": 30,\n  \"image\": \"https://images.unsplash.com/photo-1587829741301-dc798b83add3?w=500\",\n  \"description\": \"Hot-swappable switches, RGB backlight.\",\n  \"featured\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.product) pm.collectionVariables.set('productId', d.product.id);",
                  "pm.test('Created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}"
              ]
            },
            "description": "Partial update \u2014 send only the fields you want changed.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 69.99,\n  \"stock\": 45,\n  \"featured\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Delete product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}"
              ]
            },
            "description": "Admin only."
          }
        }
      ]
    },
    {
      "name": "4. Orders",
      "item": [
        {
          "name": "Place order (no auth needed)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Public checkout. Coupons: SAVE10 (10% off), WELCOME5 ($5 off).\nShipping is free over $75, else $6.99. Tax is 8%.\nStock is decremented automatically.\n\nAdd \"userId\": <id> to link the order to a logged-in user so it shows in /orders/mine.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"name\": \"Priya Sharma\",\n    \"email\": \"priya@example.com\",\n    \"address\": \"12 MG Road\",\n    \"city\": \"Hyderabad\"\n  },\n  \"items\": [\n    {\n      \"id\": 1,\n      \"qty\": 1\n    },\n    {\n      \"id\": 2,\n      \"qty\": 2\n    }\n  ],\n  \"coupon\": \"SAVE10\",\n  \"payment\": \"card\",\n  \"cardLast4\": \"4242\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.order) pm.collectionVariables.set('orderId', d.order.id);",
                  "pm.test('Order placed', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "List all orders (admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": ""
          }
        },
        {
          "name": "Filter orders by status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders?status=Pending",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "Pending"
                }
              ]
            },
            "description": "Statuses: Pending, Processing, Shipped, Delivered, Cancelled"
          }
        },
        {
          "name": "My orders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/mine",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "mine"
              ]
            },
            "description": "Any logged-in user. Only returns orders placed with a matching userId."
          }
        },
        {
          "name": "Update order status (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "{{orderId}}",
                "status"
              ]
            },
            "description": "Allowed: Pending, Processing, Shipped, Delivered, Cancelled",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Shipped\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Delete order (admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "{{orderId}}"
              ]
            },
            "description": ""
          }
        }
      ]
    },
