        },
        {
          "name": "Delete customer",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/customers/{{customerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "customers",
                "{{customerId}}"
              ]
            },
            "description": ""
          }
        }
      ]
    },
    {
      "name": "6. Stats (admin)",
      "item": [
        {
          "name": "Dashboard stats",
